# ==============================================================================
# LOCAL DEVELOPMENT SETTINGS
# ==============================================================================

# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
MAIN_DOMAIN=localhost

# Database (local Docker)
POSTGRES_DB=restaurant_db
POSTGRES_USER=restaurant_user
POSTGRES_PASSWORD=restaurant_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (local Docker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# MinIO (local Docker)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=media
MINIO_USE_SSL=False
MINIO_EXTERNAL_ENDPOINT=localhost:9000
USE_MINIO=True

# Security
FIELD_ENCRYPTION_KEY=your-32-byte-base64-encryption-key-here

# Email (for future use)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bank of Georgia (BOG) Payment Manager — sandbox defaults.
# When BOG_SANDBOX=True, the app picks the `-sandbox` hosts automatically
# (oauth2-sandbox.bog.ge, api-sandbox.bog.ge, payment-sandbox.bog.ge) and
# bakes in the sandbox webhook public key, so you only need the credentials.
# To go live, set BOG_SANDBOX=False and populate the production hosts + key.
BOG_SANDBOX=True
BOG_CLIENT_ID=
BOG_CLIENT_SECRET=
# Override only if you're connecting to production or a private test realm.
# BOG_OAUTH_URL=
# BOG_API_URL=
# Sandbox key is the default — set this only when flipping to production or if
# BOG rotates the sandbox key.
# BOG_WEBHOOK_PUBLIC_KEY=
BOG_ADD_CARD_AMOUNT=1.00
BOG_RESERVATION_DEPOSIT_AMOUNT=10.00
# Leave blank in production (derived from request host). For local sandbox tests,
# set this to your public tunnel URL so BOG can reach the webhook, e.g.
# BOG_WEBHOOK_URL=https://<your-ngrok>.ngrok.io/api/v1/payments/bog/webhook/
BOG_WEBHOOK_URL=

# ==============================================================================
# PRODUCTION SETTINGS (DigitalOcean App Platform)
# ==============================================================================
# These are set in DigitalOcean App Platform environment variables:
#
# DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require
# REDIS_URL=rediss://user:pass@host:port
# SECRET_KEY=<generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# ALLOWED_HOSTS=your-app.ondigitalocean.app
# CSRF_TRUSTED_ORIGINS=https://your-app.ondigitalocean.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
# MAIN_DOMAIN=your-domain.com
#
# For DigitalOcean Spaces (S3-compatible storage):
# MINIO_ENDPOINT=fra1.digitaloceanspaces.com
# MINIO_ACCESS_KEY=<your-spaces-access-key>
# MINIO_SECRET_KEY=<your-spaces-secret-key>
# MINIO_BUCKET_NAME=restaurant-media
# MINIO_USE_SSL=True
# MINIO_EXTERNAL_ENDPOINT=restaurant-media.fra1.cdn.digitaloceanspaces.com
